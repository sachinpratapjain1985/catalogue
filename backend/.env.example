# ==============================================================================
# Environment Configuration Template - Catalogue Backend
# ==============================================================================
PORT=5000
NODE_ENV=production

# Database config (Matches DB credentials inside docker-compose.yml)
# Note: Inside the Docker network, the DB service is named 'db', running on 5432.
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_NAME=catalogue_db

# Security Token Secret (Must be a long random string in production)
JWT_SECRET=super_secret_key_change_me_in_prod

# Image upload directory (Volume mapped inside the container)
UPLOAD_DIR=/app/uploads
